# ProductPilot 环境变量配置示例
# 使用时请复制此文件并重命名为 .env，然后填写具体的 Key。切勿将包含真实 Key 的 .env 文件提交到 Git 仓库！

# ==============================================================================
# 大语言模型与 AI 接口配置 (LLM Providers)
# ==============================================================================
# 默认大语言模型提供商 (可选: gemini, openai, anthropic, azure)
LLM_PROVIDER=gemini

# Gemini API 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro-latest

# OpenAI API 配置 (备用)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic API 配置 (备用)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ==============================================================================
# 协同办公系统集成配置 (Collaborative Tools Integration)
# ==============================================================================
# Jira 集成配置
JIRA_HOST=https://your-company.atlassian.net
JIRA_USER_EMAIL=pm_user@yourcompany.com
JIRA_API_TOKEN=your_jira_token_here

# Confluence 集成配置
CONFLUENCE_HOST=https://your-company.atlassian.net/wiki
CONFLUENCE_USER_EMAIL=pm_user@yourcompany.com
CONFLUENCE_API_TOKEN=your_confluence_token_here

# GitHub 集成配置 (用于自动提 Issue/PR 关联)
GITHUB_ACCESS_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_org_or_username
GITHUB_REPO_NAME=ProductPilot

# ==============================================================================
# 本地服务与输出路径配置
# ==============================================================================
# 调试模式 (true/false)
DEBUG_MODE=false
# 本地服务端口 (用于原型本地预览服务器)
PREVIEW_PORT=3000
# 文档与 PPT 默认输出目录 (绝对路径或相对路径)
OUTPUT_DIR=./output
