# ProductPilot - Git Ignore Rules

# 敏感配置文件与秘钥
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 系统与开发工具临时文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 依赖与打包输出
node_modules/
dist/
build/
out/
.next/
.nuxt/
.docusaurus/
.serverless/
.env.example.local

# 编译与临时运行文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ProductPilot 输出产物 (本地生成不提交)
output/ppt/*
!output/ppt/.gitkeep
output/docs/*
!output/docs/.gitkeep
output/prototypes/*
!output/prototypes/.gitkeep
output/images/*
!output/images/.gitkeep

# 本地临时草稿与私有知识库 (防止误提内部敏感数据)
knowledge/private/
examples/private/
*.tmp
*.bak
